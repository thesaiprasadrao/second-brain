# Second Brain Environment Configuration
# Copy this file to .env and fill in your values
# These will be created automatically by 'npm run setup'

# ===== CHANNEL CONFIGURATION =====
# Choose: telegram or whatsapp
CHANNEL=telegram

# If using Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=987654321

# If using WhatsApp
SELF_CHAT_JID=919876543210@s.whatsapp.net

# ===== AI MODEL CONFIGURATION =====
# Groq API Key (get free at https://console.groq.com)
GROQ_API_KEY=gsk_yourKeyHereStartingWithgsk_

# ===== STORAGE CONFIGURATION =====
# Where to save captures: docs (Google Docs) or keep (Google Keep)
STORAGE_BACKEND=docs

# ===== GOOGLE API CONFIGURATION =====
# Get these from Google Cloud Console
# The app-level credentials (provided by developer)
APP_GOOGLE_CLIENT_ID=your-app-client-id.apps.googleusercontent.com
APP_GOOGLE_CLIENT_SECRET=your-app-client-secret

# Your personal credentials (generated during setup)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=1//yourRefreshTokenHere

# ===== SCHEDULING =====
# Time for daily briefing (24-hour format HH:MM)
BRIEFING_TIME=08:00

# ===== OPTIONAL =====
# Node environment
NODE_ENV=production

# Logging level
LOG_LEVEL=info

# Database location
DATABASE_PATH=memory.db

# ===== NOTES =====
# Never commit this file to git!
# Keep your API keys secret and secure
# If you suspect any key is compromised, regenerate it immediately
