GROQ_API_KEY=
STORAGE_BACKEND=keep

# App-level Google OAuth (used for user login)
APP_GOOGLE_CLIENT_ID=
APP_GOOGLE_CLIENT_SECRET=

# Google Authentication (choose ONE method):
# Method 1: Service Account (Recommended for server apps)
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# Method 2: OAuth2 (Alternative)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

BRIEFING_TIME=08:00
SELF_CHAT_JID=

# Messaging channel
CHANNEL=whatsapp

# Telegram (if CHANNEL=telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
