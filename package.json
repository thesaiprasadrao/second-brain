{
  "name": "second-brain",
  "version": "0.1.0",
  "description": "🧠 Your personal AI second brain — self-hosted, end-to-end encrypted, zero data sharing",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "second-brain": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js dashboard",
    "dev": "node src/index.js",
    "setup": "node bin/cli.js setup",
    "send": "node bin/cli.js send",
    "logs": "tail -f second-brain.log",
    "clean": "rm -f memory.db* auth/ .env"
  },
  "keywords": [
    "ai",
    "second-brain",
    "self-hosted",
    "telegram",
    "whatsapp",
    "personal-assistant",
    "llm"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@whiskeysockets/baileys": "^6.7.5",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "groq-sdk": "^0.13.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "open": "^10.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
